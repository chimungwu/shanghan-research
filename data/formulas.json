},{"n":"白通湯","c":"少陰病","tw":3.3,"fp":{"辛":100.0},"pf":"辛","fr":["辛"],"ns":2.09,"nt":"大溫","ng":{"寒涼":0.0,"溫熱":100.0,"平":0.0},"hd":[{"n":"蔥白","w":2.0,"f":["辛"],"t":"溫"},{"n":"乾薑","w":1,"f":["辛"],"t":"溫"},{"n":"附子","w":0.3,"f":["辛"],"t":"大溫"}],"hl":"蔥白（四莖）　乾薑（一兩）　附子（一枚，生，去皮，破八片）","cm":"右三味，以水三升，煮取一升，去滓，分溫再服。"},{"n":"白通加豬膽汁湯","c":"少陰病","tw":6.3,"fp":{"辛":52.4,"鹹":39.7,"苦":7.9},"pf":"辛","fr":["辛","鹹","苦"],"ns":0.14,"nt":"平性","ng":{"寒涼":47.6,"溫熱":52.4,"平":0.0},"hd":[{"n":"蔥白","w":2.0,"f":["辛"],"t":"溫"},{"n":"乾薑","w":1,"f":["辛"],"t":"溫"},{"n":"附子","w":0.3,"f":["辛"],"t":"大溫"},{"n":"人尿","w":2.5,"f":["鹹"],"t":"寒"},{"n":"豬膽汁","w":0.5,"f":["苦"],"t":"寒"}],"hl":"蔥白（四莖）　乾薑（一兩）　附子（一枚，生，去皮，破八片）　人尿（五合）　豬膽汁（一合）","cm":"右五味，以水三升，煮取一升，去滓，內膽汁、人尿，和令相得，分溫再服。若無膽，亦可用。"},{"n":"通脈四逆湯","c":"少陰病","tw":6.5,"fp":{"甘":30.8,"辛":69.2},"pf":"辛","fr":["辛","甘"],"ns":2.23,"nt":"大溫","ng":{"寒涼":0.0,"溫熱":100.0,"平":0.0},"hd":[{"n":"甘草","w":2,"f":["甘"],"t":"溫"},{"n":"附子","w":1.5,"f":["辛"],"t":"大溫"},{"n":"乾薑","w":3,"f":["辛"],"t":"溫"}],"hl":"甘草（二兩，炙）　附子（大者一枚，生用，去皮，破八片）　乾薑（三兩，強人可四兩）","cm":"右三味，以水三升，煮取一升二合，去滓，分溫再服。其脈即出者愈。面色赤者，加蔥九莖；腹中痛者，去蔥，加芍藥二兩；嘔者，加生薑二兩；咽痛者，去芍藥，加桔梗一兩；利止、脈不出者，去桔梗，加人參二兩。病皆與方相應者，乃服之。"},{"n":"四逆散","c":"少陰病","tw":4,"fp":{"甘":25.0,"苦":75.0},"pf":"苦","fr":["苦","甘"],"ns":0.0,"nt":"平性","ng":{"寒涼":25.0,"溫熱":25.0,"平":25.0},"hd":[{"n":"甘草","w":1,"f":["甘"],"t":"溫"},{"n":"枳實","w":1,"f":["苦"],"t":"寒"},{"n":"柴胡","w":1,"f":["苦"],"t":"平"},{"n":"芍藥","w":1,"f":["苦"],"t":""}],"hl":"甘草（炙）　枳實（破，水漬，炙乾）　柴胡　芍藥","cm":"右四味，各十分，搗篩，白飲和，服方寸匕，日三服。欬者，加五味子、乾薑各五分，並主下利；悸者，加桂枝五分；小便不利者，加茯苓五分；腹中痛者，加附子一枚，炮令坼；泄利下重者，先以水五升，煮薤白三升，煮取三升，去滓，以散三方寸匕，內湯中，煮取一升半，分溫再服。"},{"n":"烏梅丸","c":"厥陰病","tw":154.0,"fp":{"酸":58.4,"辛":20.8,"苦":14.3,"甘":10.4},"pf":"酸","fr":["酸","辛","苦","甘"],"ns":0.35,"nt":"平性","ng":{"寒涼":7.8,"溫熱":23.4,"平":58.4},"hd":[{"n":"烏梅","w":90.0,"f":["酸"],"t":"平"},{"n":"細辛","w":6,"f":["辛"],"t":"溫"},{"n":"乾薑","w":10,"f":["辛"],"t":"溫"},{"n":"黃連","w":16,"f":["苦"],"t":""},{"n":"附子","w":6,"f":["辛"],"t":"溫"},{"n":"當歸","w":4,"f":["甘"],"t":"溫"},{"n