:"霍亂病","tw":6.7,"fp":{"甘":29.9,"辛":67.2,"苦":3.0},"pf":"辛","fr":["辛","甘","苦"],"ns":2.1,"nt":"大溫","ng":{"寒涼":3.0,"溫熱":97.0,"平":0.0},"hd":[{"n":"甘草","w":2,"f":["甘"],"t":"溫"},{"n":"乾薑","w":3,"f":["辛"],"t":"溫"},{"n":"附子","w":1.5,"f":["辛"],"t":"大溫"},{"n":"豬膽汁","w":0.2,"f":["苦"],"t":"寒"}],"hl":"甘草（二兩，炙）　乾薑（三兩，強人可四兩）　附子（大者一枚，生，去皮，破八片）　豬膽汁（半合）","cm":"右四味，用水三升，煮取一升二合，去滓，內豬膽汁，分溫再服，其脈即來。無豬膽，以羊膽代之。"},{"n":"枳實梔子豉湯","c":"差後病","tw":7.3,"fp":{"苦":100.0},"pf":"苦","fr":["苦"],"ns":-2.0,"nt":"大寒","ng":{"寒涼":100.0,"溫熱":0.0,"平":0.0},"hd":[{"n":"枳實","w":0.9,"f":["苦"],"t":"寒"},{"n":"梔子","w":1.4,"f":["苦"],"t":"寒"},{"n":"香豉","w":5,"f":["苦"],"t":"寒"}],"hl":"枳實（三枚，炙）　梔子（十四個，擘）　香豉（一升，綿裹）","cm":"右三味，以清漿水七升，空煮取四升，內枳實、梔子，煮取二升，下豉，更煮五六沸，去滓，溫分再服。覆令微似汗。若有宿食者，內大黃如博棋子大五六枚，服之愈。"},{"n":"牡蠣澤瀉散","c":"差後病","tw":7,"fp":{"鹹":14.3,"甘":14.3,"辛":42.9,"苦":28.6},"pf":"辛","fr":["辛","苦","鹹","甘"],"ns":-1.14,"nt":"偏寒","ng":{"寒涼":57.1,"溫熱":0.0,"平":42.9},"hd":[{"n":"牡蠣","w":1,"f":["鹹"],"t":"平"},{"n":"澤瀉","w":1,"f":["甘"],"t":"寒"},{"n":"蜀漆","w":1,"f":["辛"],"t":"平"},{"n":"葶藶子","w":1,"f":["辛"],"t":"寒"},{"n":"商陸根","w":1,"f":["辛"],"t":"平"},{"n":"海藻","w":1,"f":["苦"],"t":"寒"},{"n":"栝蔞根","w":1,"f":["苦"],"t":"寒"}],"hl":"牡蠣（熬）　澤瀉　蜀漆（暖水洗去腥）　葶藶子（熬）　商陸根（熬）　海藻（洗去鹹）　栝蔞根（各等分）","cm":"右七味，異搗，下篩為散，更於臼中治之，白飲和，服方寸匕，日三服。小便利，止後服。"},{"n":"竹葉石膏湯","c":"差後病","tw":37.5,"fp":{"苦":5.3,"辛":64.0,"甘":30.7},"pf":"辛","fr":["辛","甘","苦"],"ns":-0.37,"nt":"平性","ng":{"寒涼":48.0,"溫熱":5.3,"平":46.7},"hd":[{"n":"竹葉","w":2,"f":["苦"],"t":"平"},{"n":"石膏","w":16,"f":["辛"],"t":"微寒"},{"n":"半夏","w":8,"f":["辛"],"t":"平"},{"n":"麥門冬","w":5,"f":["甘"],"t":"平"},{"n":"人參","w":2,"f":["甘"],"t":"小寒"},{"n":"甘草","w":2,"f":["甘"],"t":"溫"},{"n":"粳米","w":2.5,"f":["甘"],"t":"平"}],"hl":"竹葉（二把）　石膏（一斤）　半夏（半斤，洗）　麥門冬（一升，去心）　人參（二兩）　甘草（二兩，炙）　粳米（半升）","cm":"右七味，以水一斗，煮取六升，去滓，內粳米，煮米熟，湯成，去米，溫服一升，日三服。"},{"n":"四逆加吳茱萸生薑湯","c":"差後病","tw":40.5,"fp":{"甘":35.8,"苦":7.4,"辛":64.2},"pf":"辛","fr":["辛","甘","苦"],"ns":1.19,"nt":"偏溫","ng":{"寒涼":0.0,"溫熱":69.1,"平":23.5},"hd":[{"n":"當歸","w":2,"f":["甘"],"t":"溫"},{"n":"芍藥","w